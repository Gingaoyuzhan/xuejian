# 依赖目录
node_modules/
**/node_modules/

# 微信小程序云函数依赖
cloudfunctions/*/node_modules/

# 锁文件（可选，如果团队统一包管理器可保留）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 环境变量文件（敏感信息）
.env
.env.local
.env.*.local

# 操作系统文件
.DS_Store
Thumbs.db

# IDE 配置
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# 微信小程序私有配置
project.private.config.json

# 编译产物
dist/
build/
*.tgz
*.tar.gz

# 临时文件
*.tmp
*.temp
.cache/
