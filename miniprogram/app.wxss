/**
 * 全局样式 - Premium Redesign V2
 */
@import "./styles/variables.wxss";

/* ========== V2 核心动效关键帧 ========== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes floatGlow {
  0%, 100% { box-shadow: 0 10rpx 30rpx rgba(37, 99, 235, 0.15); }
  50% { box-shadow: 0 20rpx 50rpx rgba(37, 99, 235, 0.25); transform: translateY(-4rpx); }
}

.fade-up {
  animation: fadeUp var(--anim-duration) var(--anim-easing) both;
}

page {
  background-color: var(--page-bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--text-color-primary);
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* 基础容器 */
.container {
  padding: var(--spacing-md);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 高级卡片样式 ========== */
.card {
  background-color: var(--card-bg-color);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  transition: all var(--anim-duration) var(--anim-easing);
  border: 1px solid rgba(255, 255, 255, 0.8);
}

.card:active {
  transform: scale(0.96); /* V2: 更明显的按压反馈 */
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.02);
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-color-dark);
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
}

.card-content {
  font-size: 28rpx;
  color: var(--text-color-secondary);
  line-height: 1.7;
}

/* ========== 现代扁平/渐变按钮 ========== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--spacing-xl);
  height: 96rpx;
  border-radius: var(--border-radius-max);
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  box-sizing: border-box;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  color: #ffffff;
  box-shadow: var(--shadow-primary);
}

.btn-primary:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(37, 99, 235, 0.15);
}

.btn-secondary {
  background-color: var(--primary-color-glass);
  color: var(--primary-color);
  backdrop-filter: blur(10px);
}

.btn-secondary:active {
  background-color: rgba(37, 99, 235, 0.15);
  transform: scale(0.98);
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid var(--border-color);
  color: var(--text-color-primary);
}

.btn-block {
  width: 100%;
}

/* ========== 精致表单元素 ========== */
.form-item {
  margin-bottom: var(--spacing-lg);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color-dark);
  margin-bottom: var(--spacing-xs);
  padding-left: 4rpx;
}

.form-label.required::after {
  content: '*';
  color: var(--danger-color);
  margin-left: 8rpx;
}
.form-label.required::before {
  display: none;
}

.form-input {
  width: 100%;
  height: 100rpx;
  padding: 0 var(--spacing-md);
  background-color: var(--page-bg-color);
  border: 2rpx solid transparent;
  border-radius: var(--border-radius-md);
  font-size: 30rpx;
  color: var(--text-color-dark);
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-input:focus {
  background-color: #ffffff;
  border-color: rgba(37, 99, 235, 0.3);
  box-shadow: 0 0 0 8rpx var(--primary-color-glass);
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--spacing-md);
  background-color: var(--page-bg-color);
  border: 2rpx solid transparent;
  border-radius: var(--border-radius-md);
  font-size: 30rpx;
  color: var(--text-color-dark);
  box-sizing: border-box;
  transition: all 0.3s ease;
  line-height: 1.6;
}

.form-textarea:focus {
  background-color: #ffffff;
  border-color: rgba(37, 99, 235, 0.3);
  box-shadow: 0 0 0 8rpx var(--primary-color-glass);
}

/* ========== 优雅列表项 ========== */
.list-item {
  background-color: var(--card-bg-color);
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 2rpx solid var(--border-color-light);
  display: flex;
  align-items: center;
  transition: background-color 0.2s;
}

.list-item:active {
  background-color: var(--page-bg-color);
}

.list-item:last-child {
  border-bottom: none;
  border-bottom-left-radius: inherit;
  border-bottom-right-radius: inherit;
}

.list-item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color-dark);
}

.list-item-desc {
  font-size: 26rpx;
  color: var(--text-color-secondary);
  margin-top: 4rpx;
}

/* ========== 空状态与加载 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  opacity: 0.8;
}

.empty-state-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: var(--spacing-lg);
  filter: grayscale(0.5) opacity(0.5);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color-secondary);
  margin-bottom: var(--spacing-xs);
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--text-color-placeholder);
}

.loading {
  padding: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--text-color-placeholder);
  font-size: 28rpx;
}

/* ========== 通用工具类 ========== */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }

.text-dark { color: var(--text-color-dark); }
.text-primary { color: var(--primary-color); }
.text-success { color: var(--success-color); }
.text-warning { color: var(--warning-color); }
.text-danger { color: var(--danger-color); }
.text-secondary { color: var(--text-color-secondary); }

.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-medium { font-weight: 500; }
.text-center { text-align: center; }

.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

/* ========== 游客登录提示（全局共享） ========== */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx 80rpx;
  animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.login-prompt-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.1));
}

.login-prompt-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-color-dark);
  margin-bottom: 12rpx;
}

.login-prompt-desc {
  font-size: 26rpx;
  color: var(--text-color-secondary);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.login-prompt-btn {
  width: 360rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(79, 70, 229, 0.3);
  transition: all 0.2s ease;
}

.login-prompt-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.2);
}

