/* pages/improvement/detail/detail.wxss */

.detail-page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #eef6ff 0%, #f8fafc 240rpx),
    var(--page-bg-color);
  padding-bottom: 160rpx;
}

.progress-card {
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #0f766e, #0d9488 55%, #2dd4bf);
  color: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(13, 148, 136, 0.18);
}

.progress-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-title {
  font-size: 28rpx;
  opacity: 0.92;
}

.progress-stage {
  font-size: 34rpx;
  font-weight: 700;
}

.progress-tip {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.92;
}

.loop-card,
.sheet-card {
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: #fffdf8;
  border-radius: 28rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.loop-title,
.sheet-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.loop-tip {
  margin-bottom: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.loop-grid {
  display: grid;
  grid-template-columns: 1fr 88rpx 1fr;
  grid-template-rows: auto 110rpx auto;
  align-items: center;
}

.loop-node {
  min-height: 140rpx;
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 2rpx solid rgba(148, 163, 184, 0.2);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.loop-node.active {
  background: rgba(13, 148, 136, 0.08);
  border-color: rgba(13, 148, 136, 0.36);
  box-shadow: 0 10rpx 24rpx rgba(13, 148, 136, 0.14);
}

.loop-node-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.loop-node-role {
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.loop-arrow {
  text-align: center;
  font-size: 42rpx;
  color: #0d9488;
  font-weight: 700;
}

.loop-arrow.horizontal {
  grid-row: 1;
}

.loop-arrow.horizontal.reverse {
  grid-row: 3;
}

.loop-arrow.corner-right {
  grid-column: 3;
  grid-row: 2;
}

.loop-arrow.corner-left {
  grid-column: 1;
  grid-row: 2;
}

.loop-center {
  grid-column: 2;
  grid-row: 2;
  padding: 16rpx 8rpx;
  text-align: center;
}

.loop-center-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.loop-center-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}

.sheet-table {
  border-top: 2rpx solid #cbd5e1;
  border-left: 2rpx solid #cbd5e1;
}

.sheet-row {
  display: flex;
}

.sheet-cell {
  min-height: 86rpx;
  border-right: 2rpx solid #cbd5e1;
  border-bottom: 2rpx solid #cbd5e1;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.sheet-cell.label {
  width: 168rpx;
  justify-content: center;
  padding: 12rpx 16rpx;
  background: #f8fafc;
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
}

.sheet-cell.value {
  flex: 1;
  padding: 0 18rpx;
  font-size: 27rpx;
  color: #0f172a;
  line-height: 1.6;
  background: #ffffff;
  word-break: break-all;
}

.sheet-section-title {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #cbd5e1;
  border-bottom: none;
  background: #f8fafc;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.content-box {
  min-height: 220rpx;
  padding: 24rpx;
  border: 2rpx solid #cbd5e1;
  background: #ffffff;
  font-size: 28rpx;
  color: #0f172a;
  line-height: 1.8;
  white-space: pre-wrap;
  box-sizing: border-box;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  width: calc(33.333% - 8rpx);
  padding-bottom: calc(33.333% - 8rpx);
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
}

.image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
}

.history-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #0d9488;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.history-content {
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-action {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.history-operator,
.history-time {
  font-size: 24rpx;
  color: #64748b;
}

.history-comment {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.7;
  white-space: pre-wrap;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 2rpx solid rgba(148, 163, 184, 0.18);
}

.action-btn {
  width: 100%;
  height: 92rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0f766e, #0d9488 55%, #2dd4bf);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 40rpx rgba(13, 148, 136, 0.24);
}

.action-btn::after {
  border: none;
}
