<!--pages/improvement/create/create.wxml-->
<view class="create-page">
  <view class="page-intro">
    <view class="intro-title">持续改进检查表</view>
    <view class="intro-desc">一级由督导或高教中心发起，二级学院或教师整改后进入复查、复核；如被退回则重新回到二级处理，形成循环闭环。</view>
  </view>

  <view class="paper-sheet">
    <view class="sheet-title">一级发起</view>

    <view class="sheet-table">
      <view class="sheet-row">
        <view class="sheet-cell label">教师姓名</view>
        <view class="sheet-cell value">
          <input
            class="cell-input"
            placeholder="请输入教师姓名"
            value="{{formData.teacherName}}"
            data-field="teacherName"
            bindinput="onInputChange"
          />
        </view>
      </view>

      <view class="sheet-row">
        <view class="sheet-cell label">所属学院</view>
        <view class="sheet-cell value">
          <input
            class="cell-input"
            placeholder="请输入所属学院"
            value="{{formData.collegeName}}"
            data-field="collegeName"
            bindinput="onInputChange"
          />
        </view>
      </view>

      <view class="sheet-row">
        <view class="sheet-cell label">检查日期</view>
        <picker
          class="sheet-cell value"
          mode="date"
          value="{{formData.inspectionDate}}"
          start="2024-01-01"
          end="2030-12-31"
          bindchange="onDateChange"
        >
          <view class="date-inline {{formData.inspectionDate ? '' : 'placeholder'}}">
            <text>{{dateDisplay.year}}</text>
            <text class="date-unit">年</text>
            <text>{{dateDisplay.month}}</text>
            <text class="date-unit">月</text>
            <text>{{dateDisplay.day}}</text>
            <text class="date-unit">日</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="sheet-section-title">检查学院存在问题</view>
    <textarea
      class="sheet-textarea large-textarea"
      placeholder="请填写检查中发现的问题"
      value="{{formData.inspectionIssues}}"
      data-field="inspectionIssues"
      bindinput="onInputChange"
      maxlength="3000"
      auto-height
      show-confirm-bar="{{false}}"
    />

    <view class="upload-section">
      <view class="sheet-section-title">问题附件</view>
      <view class="upload-tip">可上传问题截图、照片或佐证材料。</view>
      <image-uploader
        value="{{formData.issueImages}}"
        bindchange="onImageChange"
        maxCount="9"
      />
    </view>
  </view>

  <view class="submit-bar">
    <button class="submit-btn" bindtap="handleSubmit">发起持续改进</button>
  </view>
</view>
