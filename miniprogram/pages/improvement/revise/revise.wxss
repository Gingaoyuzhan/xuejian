/* pages/improvement/revise/revise.wxss */

.page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #f4f9ff 0%, #f8fafc 240rpx),
    var(--page-bg-color);
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.info-card,
.form-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #fffdf8;
  border-radius: 28rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.card-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #64748b;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.section-subtitle,
.form-label {
  display: block;
  margin: 18rpx 0 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.form-label.required::after {
  content: ' *';
  color: #dc2626;
}

.content-box,
.form-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  border: 2rpx solid #cbd5e1;
  background: #ffffff;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.8;
  color: #0f172a;
  white-space: pre-wrap;
}

.form-textarea {
  min-height: 320rpx;
}

.form-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 2rpx solid rgba(148, 163, 184, 0.18);
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ea580c, #f97316 55%, #fb923c);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 40rpx rgba(249, 115, 22, 0.24);
}

.submit-btn::after {
  border: none;
}
