/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  width: 100vw;
  background: #f4f6fc;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 40rpx;
}

/* 动态背景装饰 */
.bg-shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  z-index: 0;
  opacity: 0.8;
  animation: float 10s infinite ease-in-out alternate;
}

.bg-shape-1 {
  width: 600rpx;
  height: 600rpx;
  background: rgba(79, 70, 229, 0.4);
  top: -100rpx;
  right: -100rpx;
}

.bg-shape-2 {
  width: 500rpx;
  height: 500rpx;
  background: rgba(14, 165, 233, 0.4);
  bottom: -50rpx;
  left: -100rpx;
  animation-delay: -5s;
}

.bg-shape-3 {
  width: 400rpx;
  height: 400rpx;
  background: rgba(236, 72, 153, 0.3);
  top: 40%;
  left: 30%;
  animation-duration: 15s;
}

@keyframes float {
  0% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-40rpx) scale(1.05); }
  100% { transform: translateY(20rpx) scale(0.95); }
}

/* 毛玻璃卡片主容器 */
.glass-card {
  width: 100%;
  max-width: 680rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  border-radius: 48rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.08), 
              inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
  z-index: 10;
  box-sizing: border-box;
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 通用按钮样式 */
.btn-primary {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #4F46E5 0%, #3B82F6 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(79, 70, 229, 0.3);
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.btn-primary:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(79, 70, 229, 0.2);
}

.btn-primary::after {
  display: none;
}

/* ================= 状态1: 未授权 ================= */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.06);
  margin-bottom: 30rpx;
  border: 4rpx solid rgba(255,255,255,0.8);
}

.logo-icon {
  font-size: 80rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(0,0,0,0.1));
}

.titles {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.main-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #111827;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, #111827, #4F46E5);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.sub-title {
  font-size: 24rpx;
  color: #6B7280;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.welcome-text {
  text-align: center;
  margin-bottom: 80rpx;
}

.greeting {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.instruction {
  font-size: 28rpx;
  color: #9CA3AF;
}

.auth-btn {
  margin-top: 40rpx;
}

/* ================= 状态2: 填写信息 ================= */
.profile-header {
  display: flex;
  align-items: center;
  margin-bottom: 50rpx;
  background: rgba(255, 255, 255, 0.5);
  padding: 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
  animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  animation-delay: 0.1s;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
  margin-right: 24rpx;
}

.welcome-back {
  display: flex;
  flex-direction: column;
}

.welcome-back text:first-child {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 4rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #4B5563;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.role-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.section-tip {
  display: block;
  margin: -8rpx 0 24rpx;
  padding-left: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6B7280;
}

.role-card {
  width: 48%;
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 24rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.role-card:nth-child(1) { animation-delay: 0.2s; }
.role-card:nth-child(2) { animation-delay: 0.25s; }
.role-card:nth-child(3) { animation-delay: 0.3s; }
.role-card:nth-child(4) { animation-delay: 0.35s; }

.role-icon-box {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  transition: transform 0.3s ease;
}

.role-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #4B5563;
  transition: color 0.3s ease;
}

.role-card.active {
  background: rgba(79, 70, 229, 0.1);
  border-color: #4F46E5;
  box-shadow: 0 8rpx 24rpx rgba(79, 70, 229, 0.15);
}

.role-card.active .role-icon-box {
  transform: scale(1.15) translateY(-4rpx);
}

.role-card.active .role-name {
  color: #4F46E5;
  font-weight: 700;
}

.check-circle {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background: #4F46E5;
  border-radius: 50%;
  box-shadow: 0 0 0 6rpx rgba(79, 70, 229, 0.2);
}

.input-group {
  margin-bottom: 50rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  height: 96rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.02);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.input-wrapper:nth-child(1) { animation-delay: 0.4s; }
.input-wrapper:nth-child(2) { animation-delay: 0.45s; }
.input-wrapper:nth-child(3) { animation-delay: 0.5s; }
.input-wrapper:nth-child(4) { animation-delay: 0.55s; }

.input-wrapper:focus-within {
  border-color: rgba(79, 70, 229, 0.4);
  background: #ffffff;
  box-shadow: 0 0 0 6rpx rgba(79, 70, 229, 0.1);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  opacity: 0.6;
}

.custom-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #111827;
}

.input-placeholder {
  color: #9CA3AF;
  font-size: 28rpx;
}

.submit-btn {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.btn-arrow {
  margin-left: 8rpx;
  transition: transform 0.3s ease;
}

.submit-btn:active .btn-arrow {
  transform: translateX(8rpx);
}

/* ========== 协议勾选 ========== */
.agreement-check {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0 28rpx;
  gap: 12rpx;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  border: 3rpx solid #D1D5DB;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
  transition: all 0.2s ease;
  background: #ffffff;
}

.check-box.checked {
  background: #4F46E5;
  border-color: #4F46E5;
}

.check-mark {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
}

.agreement-text {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  line-height: 1.6;
}

.agreement-label {
  font-size: 24rpx;
  color: #9CA3AF;
}

.agreement-link {
  font-size: 24rpx;
  color: #4F46E5;
  font-weight: 500;
}

