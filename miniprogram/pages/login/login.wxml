<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="bg-shape bg-shape-1"></view>
  <view class="bg-shape bg-shape-2"></view>
  <view class="bg-shape bg-shape-3"></view>

  <view class="glass-card">
    <view class="brand-header">
      <view class="brand-icon">📊</view>
      <view class="brand-copy">
        <text class="brand-title">廊坊师范学院教学质量监控系统</text>
        <text class="brand-sub-title">Teaching Quality Monitoring</text>
      </view>
    </view>

    <view class="profile-header">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="welcome-back">
        <text>请填写</text>
        <text class="nickname">{{userInfo.nickName || '登录信息'}}</text>
      </view>
      <button
        class="profile-auth-btn"
        bindtap="getUserProfile"
        loading="{{authorizing}}"
        disabled="{{authorizing}}"
      >
        {{userInfo.avatarUrl ? '更新头像昵称' : '授权头像昵称'}}
      </button>
    </view>

    <view class="form-container">
      <text class="section-title">选择您的身份</text>
      <text class="section-tip">可先浏览功能服务，决定使用后再填写信息登录。微信头像昵称授权不是前置条件；教师可自助注册，校领导、学校督导、高教中心等身份需由管理员预先开通。</text>
      <view class="selected-summary {{selectedRoles.length > 0 ? 'active' : ''}}">
        <text class="selected-label">已选身份</text>
        <text class="selected-value">{{selectedRoleText || '未选择'}}</text>
      </view>

      <view class="role-grid">
        <view
          class="role-card {{selectedRoles.indexOf(item.value) > -1 ? 'active' : ''}}"
          wx:for="{{roleList}}"
          wx:key="value"
          data-role="{{item.value}}"
          bindtap="selectRole"
        >
          <view class="role-icon-box">{{item.icon}}</view>
          <text class="role-name">{{item.label}}</text>
          <text class="role-state">{{selectedRoles.indexOf(item.value) > -1 ? '已选中' : '点击选择'}}</text>
          <view class="check-circle" wx:if="{{selectedRoles.indexOf(item.value) > -1}}">
            <text class="check-circle-text">✓</text>
          </view>
        </view>
      </view>

      <view class="input-group">
        <view class="input-wrapper">
          <text class="input-icon">📱</text>
          <input
            class="custom-input"
            type="number"
            placeholder="您的手机号码"
            placeholder-class="input-placeholder"
            value="{{phone}}"
            bindinput="onPhoneInput"
            maxlength="11"
          />
        </view>

        <view class="prefill-tip {{prefillMatched ? 'matched' : ''}}" wx:if="{{prefillMessage}}">
          <text>{{prefillMessage}}</text>
        </view>

        <view class="input-wrapper {{prefillLocked ? 'locked' : ''}}">
          <text class="input-icon">👤</text>
          <input
            class="custom-input"
            placeholder="您的真实姓名"
            placeholder-class="input-placeholder"
            value="{{name}}"
            bindinput="onNameInput"
            disabled="{{prefillLocked}}"
          />
        </view>

        <view class="input-wrapper {{prefillLocked ? 'locked' : ''}}">
          <text class="input-icon">🏢</text>
          <input
            class="custom-input"
            placeholder="所属部门或单位"
            placeholder-class="input-placeholder"
            value="{{department}}"
            bindinput="onDepartmentInput"
            disabled="{{prefillLocked}}"
          />
        </view>

        <view class="input-wrapper" wx:if="{{selectedRoles.indexOf('admin') > -1}}">
          <text class="input-icon">🔑</text>
          <input
            class="custom-input"
            type="password"
            placeholder="管理员授权码"
            placeholder-class="input-placeholder"
            value="{{password}}"
            bindinput="onPasswordInput"
          />
        </view>
      </view>

      <view class="agreement-check">
        <view class="check-box {{agreed ? 'checked' : ''}}" bindtap="toggleAgreement">
          <text wx:if="{{agreed}}" class="check-mark">✓</text>
        </view>
        <view class="agreement-text">
          <text class="agreement-label">我已阅读并同意</text>
          <text class="agreement-link" bindtap="openServiceAgreement">《用户服务协议》</text>
          <text class="agreement-label">和</text>
          <text class="agreement-link" bindtap="openPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>

      <button class="btn-primary submit-btn" bindtap="handleLogin">
        <text class="btn-text">进入系统</text>
        <text class="btn-arrow">→</text>
      </button>
    </view>
  </view>
</view>
