/* pages/observation/audit-detail/audit-detail.wxss */

.detail-page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #eef4ff 0%, #f8fafc 240rpx),
    var(--page-bg-color);
  padding-bottom: 160rpx;
}

.sheet-card {
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: #fffdf8;
  border-radius: 28rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.sheet-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.sheet-table {
  border-top: 2rpx solid #cbd5e1;
  border-left: 2rpx solid #cbd5e1;
}

.sheet-row {
  display: flex;
}

.sheet-row.multi-column .sheet-cell.label {
  width: 108rpx;
}

.sheet-cell {
  min-height: 86rpx;
  border-right: 2rpx solid #cbd5e1;
  border-bottom: 2rpx solid #cbd5e1;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.sheet-cell.label {
  width: 150rpx;
  justify-content: center;
  padding: 12rpx 16rpx;
  background: #f8fafc;
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
}

.sheet-cell.label.wide {
  width: 170rpx;
}

.sheet-cell.value {
  flex: 1;
  padding: 0 18rpx;
  font-size: 27rpx;
  color: #0f172a;
  line-height: 1.6;
  background: #ffffff;
  word-break: break-all;
}

.sheet-cell.value.flex-cell {
  flex: 1.6;
}

.sheet-cell.value.fixed-cell {
  width: 220rpx;
  flex: none;
}

.sheet-cell.value.grow {
  flex: 1;
}

.sheet-section-title {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #cbd5e1;
  border-bottom: none;
  background: #f8fafc;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.content-box {
  min-height: 220rpx;
  padding: 24rpx;
  border: 2rpx solid #cbd5e1;
  background: #ffffff;
  font-size: 28rpx;
  color: #0f172a;
  line-height: 1.8;
  white-space: pre-wrap;
  box-sizing: border-box;
}

.content-box.large-box {
  min-height: 320rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  width: calc(33.333% - 8rpx);
  padding-bottom: calc(33.333% - 8rpx);
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
}

.image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.meta-tip {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #64748b;
}

.audit-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx;
  border: 2rpx solid #cbd5e1;
  background: #ffffff;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.8;
  color: #0f172a;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 2rpx solid rgba(148, 163, 184, 0.18);
}

.action-btn {
  flex: 1;
  height: 92rpx;
  border: none;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.action-btn::after {
  border: none;
}

.reject-btn {
  background: rgba(239, 68, 68, 0.12);
  color: #dc2626;
}

.approve-btn {
  background: linear-gradient(135deg, #059669, #10b981 55%, #34d399);
  color: #ffffff;
}
