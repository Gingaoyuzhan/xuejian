/* pages/observation/audit/audit.wxss - Premium Redesign */

.audit-page {
  min-height: 100vh;
  background-color: var(--page-bg-color);
}

.list-container {
  padding: 20rpx 28rpx;
}

.list-item {
  background-color: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  border: var(--glass-border);
  animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.list-item:nth-child(1) { animation-delay: 0.05s; }
.list-item:nth-child(2) { animation-delay: 0.1s; }
.list-item:nth-child(3) { animation-delay: 0.15s; }
.list-item:nth-child(4) { animation-delay: 0.2s; }
.list-item:nth-child(5) { animation-delay: 0.25s; }
.list-item:nth-child(n+6) { animation-delay: 0.3s; }

.list-item:active {
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 0 0 0 rgba(0,0,0,0);
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.item-course {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color-dark);
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-info {
  margin-bottom: 12rpx;
}

.info-row {
  display: flex;
  font-size: 26rpx;
  line-height: 2;
}

.info-label {
  color: var(--text-color-secondary);
  flex-shrink: 0;
  min-width: 100rpx;
}

.info-value {
  color: var(--text-color-primary);
  flex: 1;
  font-weight: 500;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--border-color-light);
}

.item-time {
  font-size: 24rpx;
  color: var(--text-color-placeholder);
}

.item-arrow {
  font-size: 28rpx;
  color: var(--text-color-placeholder);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  animation: fadeUp 0.6s ease-out;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
  filter: drop-shadow(0 10rpx 20rpx rgba(0,0,0,0.05));
}

.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-color-secondary);
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-color-secondary);
  font-size: 28rpx;
}
