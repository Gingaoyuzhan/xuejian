/* pages/observation/create/create.wxss */

.create-page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #eef4ff 0%, #f8fafc 220rpx),
    var(--page-bg-color);
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.page-intro {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1d4ed8, #2563eb 58%, #60a5fa);
  color: #ffffff;
  box-shadow: 0 20rpx 50rpx rgba(37, 99, 235, 0.18);
}

.intro-title {
  font-size: 36rpx;
  font-weight: 700;
}

.intro-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  opacity: 0.92;
}

.paper-sheet {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #fffdf8;
  border-radius: 28rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.sheet-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.sheet-table {
  border-top: 2rpx solid #cbd5e1;
  border-left: 2rpx solid #cbd5e1;
}

.sheet-row {
  display: flex;
}

.sheet-row.multi-column .sheet-cell.label {
  width: 108rpx;
}

.sheet-cell {
  min-height: 88rpx;
  border-right: 2rpx solid #cbd5e1;
  border-bottom: 2rpx solid #cbd5e1;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.sheet-cell.label {
  width: 150rpx;
  justify-content: center;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
  background: #f8fafc;
}

.sheet-cell.label.wide {
  width: 170rpx;
}

.sheet-cell.value {
  flex: 1;
  padding: 0 18rpx;
  background: #ffffff;
}

.sheet-cell.value.flex-cell {
  flex: 1.6;
}

.sheet-cell.value.fixed-cell {
  width: 220rpx;
  flex: none;
}

.sheet-cell.value.grow {
  flex: 1;
}

.date-inline {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  width: 100%;
  min-height: 88rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.date-inline.placeholder {
  color: #94a3b8;
}

.date-unit {
  margin-right: 10rpx;
}

.date-weekday {
  margin-left: 12rpx;
}

.lesson-inline {
  display: flex;
  align-items: center;
  width: 100%;
  font-size: 28rpx;
  color: #0f172a;
}

.lesson-input {
  flex: 1;
  height: 72rpx;
  margin: 0 12rpx;
  font-size: 28rpx;
  text-align: center;
}

.cell-input {
  width: 100%;
  height: 72rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.sheet-section-title {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #cbd5e1;
  border-bottom: none;
  background: #f8fafc;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.sheet-textarea {
  width: 100%;
  min-height: 360rpx;
  padding: 22rpx;
  border: 2rpx solid #cbd5e1;
  font-size: 28rpx;
  line-height: 1.8;
  color: #0f172a;
  box-sizing: border-box;
  background: #ffffff;
}

.large-textarea {
  min-height: 420rpx;
}

.upload-section {
  margin-top: 16rpx;
}

.upload-tip {
  margin: -2rpx 0 18rpx;
  padding: 0 4rpx;
  font-size: 24rpx;
  color: #64748b;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 2rpx solid rgba(148, 163, 184, 0.18);
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1d4ed8, #2563eb 58%, #60a5fa);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 40rpx rgba(37, 99, 235, 0.24);
}

.submit-btn::after {
  border: none;
}
